FROM ghcr.io/astral-sh/uv:python3.11-alpine

WORKDIR /app

RUN apk add --no-cache git

COPY pyproject.toml uv.lock ./
RUN uv sync --no-dev --frozen

COPY app/ ./app/
COPY admin/ ./admin/

ENV PYTHONUNBUFFERED=1
EXPOSE 8100

CMD ["uv", "run", "uvicorn", "admin.app:app", "--host", "0.0.0.0", "--port", "8100"]
