{
  "base_url": "https://api-audience.yandex.ru/v2/management",
  "auth": {
    "token": "${YANDEX_AUDIENCE_TOKEN}"
  },
  "default_headers": {
    "Content-Type": "application/json"
  },
  "resources": {
    "segments": {
      "path": "/segments",
      "method": "GET",
      "description": "Получение списка сегментов",
      "parameters": {
        "offset": {
          "type": "integer",
          "required": false,
          "description": "Смещение"
        },
        "limit": {
          "type": "integer",
          "required": false,
          "description": "Количество сегментов на странице"
        },
        "name": {
          "type": "string",
          "required": false,
          "description": "Фильтр по названию сегмента"
        }
      }
    },
    "segment": {
      "path": "/segments/{segment_id}",
      "method": "GET",
      "description": "Получение информации о сегменте",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        }
      }
    },
    "segment_create": {
      "path": "/segments",
      "method": "POST",
      "description": "Создание сегмента",
      "parameters": {
        "segment": {
          "type": "object",
          "required": true,
          "description": "Параметры сегмента",
          "properties": {
            "name": {
              "type": "string",
              "required": true,
              "description": "Название сегмента"
            },
            "category_id": {
              "type": "integer",
              "required": false,
              "description": "Идентификатор категории"
            },
            "passport_user_id": {
              "type": "integer",
              "required": false,
              "description": "Идентификатор пользователя Яндекса"
            },
            "is_default": {
              "type": "boolean",
              "required": false,
              "description": "Является ли сегментом по умолчанию"
            },
            "lifetime": {
              "type": "integer",
              "required": false,
              "description": "Время жизни сегмента в днях"
            },
            "data": {
              "type": "string",
              "required": false,
              "description": "Данные сегмента"
            },
            "kind": {
              "type": "string",
              "required": false,
              "description": "Тип сегмента",
              "enum": ["uploaded_file", "metrika_segment", "lookalike", "mobile_operator", "retargeting", "combined", "crm"]
            },
            "conditions": {
              "type": "array",
              "required": false,
              "description": "Условия сегмента"
            }
          }
        }
      }
    },
    "segment_update": {
      "path": "/segments/{segment_id}",
      "method": "PUT",
      "description": "Изменение сегмента",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        },
        "segment": {
          "type": "object",
          "required": true,
          "description": "Параметры сегмента для изменения"
        }
      }
    },
    "segment_delete": {
      "path": "/segments/{segment_id}",
      "method": "DELETE",
      "description": "Удаление сегмента",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        }
      }
    },
    "segment_upload": {
      "path": "/segments/{segment_id}/upload",
      "method": "POST",
      "description": "Загрузка данных в сегмент",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        },
        "data": {
          "type": "string",
          "required": true,
          "description": "Данные для загрузки"
        }
      }
    },
    "segment_upload_check": {
      "path": "/segments/{segment_id}/upload/check",
      "method": "GET",
      "description": "Проверка статуса загрузки",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        }
      }
    },
    "segment_update_upload": {
      "path": "/segments/{segment_id}/update_upload",
      "method": "POST",
      "description": "Обновление данных в сегменте",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        },
        "data": {
          "type": "string",
          "required": true,
          "description": "Данные для обновления"
        }
      }
    },
    "segment_reach": {
      "path": "/segments/{segment_id}/reach",
      "method": "GET",
      "description": "Получение охвата сегмента",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        },
        "date": {
          "type": "string",
          "required": false,
          "description": "Дата для оценки охвата"
        }
      }
    },
    "segment_logs": {
      "path": "/segments/{segment_id}/logs",
      "method": "GET",
      "description": "Получение логов загрузки",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        }
      }
    },
    "segment_status": {
      "path": "/segments/{segment_id}/status",
      "method": "GET",
      "description": "Получение статуса сегмента",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        }
      }
    },
    "segment_progress": {
      "path": "/segments/{segment_id}/progress",
      "method": "GET",
      "description": "Получение прогресса обработки сегмента",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        }
      }
    },
    "permissions": {
      "path": "/segments/{segment_id}/permissions",
      "method": "GET",
      "description": "Получение списка разрешений на сегмент",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        }
      }
    },
    "permission_create": {
      "path": "/segments/{segment_id}/permissions",
      "method": "POST",
      "description": "Создание разрешения на сегмент",
      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        },
        "permission": {
          "type": "object",
          "required": true,
          "description": "Параметры разрешения",
          "properties": {
            "passport_user_id": {
              "type": "integer",
              "required": true,
              "description": "Идентификатор пользователя Яндекса"
            },
            "role": {
              "type": "string",
              "required": true,
              "description": "Роль пользователя",
              "enum": ["owner", "editor", "viewer"]
            }
          }
        }
      }
    },
    "permission_delete": {
      "path": "/segments/{segment_id}/permissions/{user_id}",
      "method": "DELETE",
