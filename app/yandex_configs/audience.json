      "parameters": {
        "segment_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор сегмента"
        },
        "user_id": {
          "type": "integer",
          "required": true,
          "description": "Идентификатор пользователя"
        }
      }
    },
    "accounts": {
      "path": "/accounts",
      "method": "GET",
      "description": "Получение списка аккаунтов"
    },
    "representatives": {
