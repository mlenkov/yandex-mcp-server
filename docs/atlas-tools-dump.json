    "name": "feedback",
    "title": "Фидбэк",
    "description": "Submit redacted MCP failure feedback.",
    "inputSchema": {
      "$defs": {
        "FeedbackDiagnosticAttachmentInput": {
          "additionalProperties": false,
          "properties": {
            "file_name": {
              "maxLength": 180,
              "minLength": 1,
              "type": "string"
            },
            "content": {
              "maxLength": 16777216,
              "minLength": 1,
              "type": "string"
            },
            "mime_type": {
              "anyOf": [
                {
                  "maxLength": 128,
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            }
          },
          "required": [
            "file_name",
            "content"
          ],
          "type": "object"
        }
      },
      "additionalProperties": false,
      "properties": {
        "reason": {
          "default": "tool_error",
          "enum": [
            "tool_error",
            "validation_error",
            "provider_error",
            "unexpected_response",
            "first_attempt_failed",
            "other"
          ],
          "type": "string"
        },
        "attempted_tool": {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        "attempted_action": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "attempted_arguments": {
          "type": "object"
        },
        "response": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "agent_summary": {
          "maxLength": 5000,
          "minLength": 10,
          "type": "string"
        },
        "retry_count": {
          "anyOf": [
            {
              "maximum": 20,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "extra_context": {
          "type": "object"
        },
        "diagnostic_files": {
          "items": {
            "$ref": "#/$defs/FeedbackDiagnosticAttachmentInput"
          },
          "maxItems": 3,
          "type": "array"
        }
      },
      "required": [
        "attempted_tool",
        "agent_summary"
      ],
      "type": "object"
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": false,
      "idempotentHint": false,
      "openWorldHint": false
    },
