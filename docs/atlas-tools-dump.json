      "additionalProperties": false,
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "feedback_id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "pii_redacted": {
          "type": "boolean"
        },
        "stored_payload_truncated": {
          "type": "boolean"
        }
      },
      "required": [
        "ok",
        "feedback_id",
        "status",
        "pii_redacted",
        "stored_payload_truncated"
      ],
      "type": "object"
